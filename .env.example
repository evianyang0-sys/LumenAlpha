# Copy this file to .env.local and restart the dashboard server.
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-pro
USER_DB_PATH=data/lumenalpha_users.sqlite

# Optional: return local mock AI analysis without a real API key.
# DEEPSEEK_MOCK=1

# Optional: enable only when a local proxy causes Node fetch to fail with
# SELF_SIGNED_CERT_IN_CHAIN.
# NODE_TLS_REJECT_UNAUTHORIZED=0
